{
    "name": "ROS 2 ARDUPILT Env",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "USERNAME": "ros",
            "USER_UID": "1000",
            "USER_GID": "1000"
        }
    },
    "remoteUser": "ros",
    "runArgs": [
        "--network=host",
        "--privileged",
        "--env=DISPLAY=${env:DISPLAY}",
        "--env=QT_X11_NO_MITSHM=1",
        "--volume=/tmp/.X11-unix:/tmp/.X11-unix:rw"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-iot.vscode-ros",
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack",
                "twxs.cmake",
                "mhutchie.git-graph"
            ],
            "settings": {
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash"
                    }
                },
                "terminal.integrated.defaultProfile.linux": "bash"
            }
        }
    },
    "postCreateCommand": "sudo rosdep update && sudo apt-get update"
}